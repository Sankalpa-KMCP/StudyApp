{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for Study Dashboard",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "core:tray:default",
    "notification:default",
    "autostart:default",
    "global-shortcut:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    }
  ]
}
