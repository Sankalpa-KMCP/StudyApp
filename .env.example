# Study Dashboard — optional environment variables
# Copy to .env.local or .env when needed. Normal development does not require a .env file.

# Enables the mock sync adapter for Playwright folder-sync E2E tests.
# The e2e-sync Playwright project sets this on its dev server; copy locally if you run sync tests against your own dev server.
VITE_E2E_SYNC=1

# Base URL for screenshot capture in CI (playwright.screenshots.config.ts).
# CI points at the production preview, e.g. http://localhost:4173/StudyApp
SCREENSHOT_BASE_URL=http://localhost:4173

# Optional: Chromatic project token for visual regression testing in CI.
# Configure as a GitHub Actions secret; not required for local development.
CHROMATIC_PROJECT_TOKEN=your_token_here
