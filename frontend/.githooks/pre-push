#!/bin/sh
# Repository pre-push hook: reject pushes unless all commit author/committer
# emails and the local git user.email equal the allowed address.
#
# Install: git -C "$(pwd)" config core.hooksPath .githooks
# Note: This is a client-side hook. For robust enforcement configure server-side
# protection (protected branches or server-side hooks).

ALLOWED_EMAIL="it25100142@my.sliit.lk"

fail() {
  echo "ERROR: $1" 1>&2
  exit 1
}

# Check local git user.email
LOCAL_EMAIL=$(git config user.email || true)
if [ -z "$LOCAL_EMAIL" ]; then
  fail "local git user.email is not set. Set it to $ALLOWED_EMAIL or configure hooks accordingly."
fi
if [ "$LOCAL_EMAIL" != "$ALLOWED_EMAIL" ]; then
  fail "local git user.email ($LOCAL_EMAIL) does not match required $ALLOWED_EMAIL"
fi

# Read refs from stdin. For each ref being pushed, examine commits that would be pushed
while read local_ref local_sha remote_ref remote_sha; do
  # If deleting a branch, skip
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # If remote sha is all zeros (new branch), compare from empty tree
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    commit_range="$local_sha"
  else
    commit_range="$remote_sha..$local_sha"
  fi

  # List commits being pushed
  commits=$(git rev-list $commit_range) || true
  for c in $commits; do
    # Check author and committer emails
    author_email=$(git show -s --format='%ae' $c 2>/dev/null || true)
    committer_email=$(git show -s --format='%ce' $c 2>/dev/null || true)

    if [ -n "$author_email" ] && [ "$author_email" != "$ALLOWED_EMAIL" ]; then
      fail "commit $c author email ($author_email) is not allowed. All commits must use $ALLOWED_EMAIL"
    fi
    if [ -n "$committer_email" ] && [ "$committer_email" != "$ALLOWED_EMAIL" ]; then
      fail "commit $c committer email ($committer_email) is not allowed. All commits must use $ALLOWED_EMAIL"
    fi
  done
done

exit 0

